# RAVAND OS — Environment Variables
# این فایل را با اطلاعات واقعی پر کن
# هرگز این فایل را در Git آپلود نکن!

# کلید OpenRouter (از openrouter.ai بگیر)
OPENROUTER_API_KEY=sk-or-v1-اینجا-کلیدت-را-بذار

# مدل هوش مصنوعی (یکی از گزینه‌های زیر را انتخاب کن)
# گزینه ۱: DeepSeek — قوی و رایگان
OPENROUTER_MODEL=deepseek/deepseek-r1-0528

# گزینه ۲: Claude Haiku — سریع و ارزان
# OPENROUTER_MODEL=anthropic/claude-3-haiku

# گزینه ۳: GPT-4o Mini — متعادل
# OPENROUTER_MODEL=openai/gpt-4o-mini

# حالت debug
DEBUG=true
