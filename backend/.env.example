# RAVAND OS – Environment Configuration
# Copy this file to .env and adjust values for your machine.
# No secrets. No API keys. Entirely local.

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=RAVAND OS
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ── Ollama AI Engine ───────────────────────────────────────────────────────────
# Ollama must be running locally: ollama serve
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_DELAY=1.5
OLLAMA_STREAM=false

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite for now. Switch to PostgreSQL later by changing this URL only.
DATABASE_URL=sqlite:///./ravand_os.db
DATABASE_ECHO=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ── Company Profile ────────────────────────────────────────────────────────────
COMPANY_NAME=FabLab Ravand
COMPANY_TAGLINE=جایی که ایده‌ها جان می‌گیرن
COMPANY_LOCATION=Zahedan, Iran – Nogam Science and Technology Park

# ── API ────────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
